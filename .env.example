# ── Ambiente ──────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=TROQUE_POR_UMA_STRING_ALEATORIA_LONGA_E_SEGURA

# ── Banco de Dados ─────────────────────────────────────────────
# SQLite (padrão):
DATABASE_URL=sqlite:///rdsolucoes.db
# PostgreSQL (produção):
# DATABASE_URL=postgresql://usuario:senha@localhost/rdsolucoes

# ── Mercado Pago ───────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MP_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MP_WEBHOOK_SECRET=CHAVE_SECRETA_DO_WEBHOOK

# ── E-mail ─────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu@email.com.br
MAIL_PASSWORD=senha_de_app_do_gmail
MAIL_DEFAULT_SENDER=RD Soluções OS <seu@email.com.br>

# ── Site ───────────────────────────────────────────────────────
BASE_URL=https://rdsolucoes.com.br
SITE_NAME=RD Soluções OS

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@rdsolucoes.com.br
ADMIN_PASSWORD=TROQUE_IMEDIATAMENTE

# ── Segurança ─────────────────────────────────────────────────
WTF_CSRF_TIME_LIMIT=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
